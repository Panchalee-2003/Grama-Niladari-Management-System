<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Certificate</title>
    <style>
        @media print {
            body { -webkit-print-color-adjust: exact; print-color-adjust: exact; margin: 0; }
            @page {
                size: A4;
                margin: 1cm;
            }
        }
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 20px;
            color: #333;
            background-color: #fff;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 2px solid #000;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        .cert-id-box {
            font-size: 14px;
        }
        .cert-id-number {
            font-weight: bold;
            font-size: 18px;
            color: #000;
            margin-top: 5px;
        }
        .qr-code img {
            width: 100px;
            height: 100px;
        }
        .title {
            text-align: center;
            font-size: 26px;
            font-weight: bold;
            margin-bottom: 40px;
            text-transform: capitalize;
            color: #111;
        }
        .grid-details {
            display: grid;
            grid-template-columns: 250px 1fr;
            row-gap: 15px;
            font-size: 14px;
            line-height: 1.5;
        }
        .grid-label {
            font-weight: bold;
            color: #444;
            display: flex;
            justify-content: space-between;
            padding-right: 15px;
        }
        .grid-value {
            color: #000;
            white-space: pre-wrap;
        }
        .dependents-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 25px;
            margin-bottom: 40px;
        }
        .dependents-table th, .dependents-table td {
            border: 1px solid #ccc;
            padding: 10px;
            text-align: left;
            font-size: 14px;
        }
        .dependents-table th {
            background-color: #f8f9fa;
            font-weight: bold;
            color: #333;
        }
        .signatures {
            margin-top: 70px;
            display: flex;
            justify-content: flex-end;
        }
        .signature-box {
            text-align: center;
            width: 300px;
        }
        .ds-signature-box {
            text-align: center;
            width: 300px;
        }
        .signatures-both {
            margin-top: 70px;
            display: flex;
            justify-content: space-between;
        }
        .signature-img {
            max-width: 200px;
            max-height: 80px;
            margin-bottom: 10px;
        }
        .caption {
            font-size: 12px;
            color: #555;
            border-top: 1px dashed #aaa;
            padding-top: 10px;
            margin-top: 5px;
        }
        .notes-section {
            margin-top: 40px;
            padding: 15px;
            background-color: #fefefe;
            border: 1px solid #eee;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="cert-id-box">
            <div style="color: #666;">Certificate ID</div>
            <div class="cert-id-number"><%= certificate_id %></div>
            <div style="margin-top: 10px; color: #555; font-size: 13px;">Issued on: <strong><%= issued_at %></strong></div>
        </div>
        <div class="qr-code">
            <img src="<%= qr_code_data_uri %>" alt="QR Code">
        </div>
    </div>

    <div class="title"><%= cert_type %></div>

    <% if (cert_type === "Notification of the death of a pensioner") { %>
        <%
            const pensionerName    = (dynamic_data && dynamic_data.pensioner_name)    ? dynamic_data.pensioner_name    : (applicant_name || '—');
            const pensionerAddress = (dynamic_data && dynamic_data.address)            ? dynamic_data.address            : '—';
            const dateRetirement   = (dynamic_data && dynamic_data.date_of_retirement) ? dynamic_data.date_of_retirement : '—';
            const pensionerNic     = (dynamic_data && dynamic_data.pensioner_nic)      ? dynamic_data.pensioner_nic      : (nic_number || '—');
            const pensionNumber    = (dynamic_data && dynamic_data.pension_number)     ? dynamic_data.pension_number     : '—';
            const dateDeath        = (dynamic_data && dynamic_data.date_of_death)      ? dynamic_data.date_of_death      : '—';
        %>
        <div class="grid-details">
            <div class="grid-label"><span>Name of the Pensioner</span><span>:</span></div>
            <div class="grid-value"><%= pensionerName %></div>

            <div class="grid-label"><span>Address</span><span>:</span></div>
            <div class="grid-value"><%= pensionerAddress %></div>

            <div class="grid-label"><span>Date of Retirement</span><span>:</span></div>
            <div class="grid-value"><%= dateRetirement %></div>

            <div class="grid-label"><span>NIC Number</span><span>:</span></div>
            <div class="grid-value"><%= pensionerNic %></div>

            <div class="grid-label"><span>Pension Number</span><span>:</span></div>
            <div class="grid-value"><%= pensionNumber %></div>

            <div class="grid-label"><span>Date of Death</span><span>:</span></div>
            <div class="grid-value"><%= dateDeath %></div>
        </div>

        <% if (dynamic_data && dynamic_data.dependents && Array.isArray(dynamic_data.dependents) && dynamic_data.dependents.length > 0) { %>
            <h4 style="margin-top: 40px; margin-bottom: 15px; font-size: 16px;">Information Regarding Dependents</h4>
            <table class="dependents-table">
                <thead>
                    <tr>
                        <th style="width: 50px;">No.</th>
                        <th>Name</th>
                        <th>Relationship</th>
                        <th style="width: 80px;">Age</th>
                    </tr>
                </thead>
                <tbody>
                    <% dynamic_data.dependents.forEach((dep, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= dep.name || '—' %></td>
                        <td><%= dep.relationship || '—' %></td>
                        <td><%= dep.age || '—' %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>

        <% if (dynamic_data && dynamic_data.notes) { %>
            <div class="notes-section">
                <h4 style="margin-top: 0; margin-bottom: 10px;">Notes</h4>
                <div style="font-size: 14px; white-space: pre-wrap;"><%= dynamic_data.notes %></div>
            </div>
        <% } %>

        <%/* GN signature only – no DS block for this cert type */%>
        <div class="signatures">
            <div class="signature-box">
                <% if (gn_signature_img) { %>
                    <img class="signature-img" src="<%= gn_signature_img %>" alt="Grama Niladhari Signature">
                <% } else { %>
                    <div style="height: 80px; line-height: 80px; font-style: italic; color: #999;">Grama Niladhari</div>
                <% } %>
                <div class="caption">
                    <strong>Grama Niladhari (<%= (dynamic_data && dynamic_data.gn_name) ? dynamic_data.gn_name : "Maspanna Division" %>)</strong><br>
                    Digitally Signed
                </div>
            </div>
        </div>

    <% } else if (cert_type === "Request for financial assistance from the President's fund for medical treatment") { %>
        <%
            const { 
                patient_name, patient_nic, patient_address, patient_house_no, patient_village, patient_gn_division, patient_marital_status,
                family_incomes_list, assets_list, bank_deposits_list,
                cost_personal, cost_etf, cost_nitf, cost_workplace, cost_insurance, cost_ngos, cost_donations, cost_loans, cost_other_details,
                prev_assistance, prev_amount, prev_date, prev_illness, prev_file_number,
                gn_recommendation, gn_reason
            } = dynamic_data || {};
        %>

        <h3 style="font-size: 15px; margin-top: 10px; border-bottom: 1px solid #000; padding-bottom: 5px;">01. Patient's Information</h3>
        <div class="grid-details">
            <div class="grid-label"><span>01.1 Full Name</span><span>:</span></div>
            <div class="grid-value"><%= patient_name || '—' %></div>
            <div class="grid-label"><span>01.2 NIC Number</span><span>:</span></div>
            <div class="grid-value"><%= patient_nic || '—' %></div>
            <div class="grid-label"><span>01.3 Residential Address</span><span>:</span></div>
            <div class="grid-value"><%= patient_address || '—' %></div>
            <div class="grid-label"><span>01.4 House Number</span><span>:</span></div>
            <div class="grid-value"><%= patient_house_no || '—' %></div>
            <div class="grid-label"><span>01.5 Village/Street</span><span>:</span></div>
            <div class="grid-value"><%= patient_village || '—' %></div>
            <div class="grid-label"><span>01.6 GN Division</span><span>:</span></div>
            <div class="grid-value"><%= patient_gn_division || '—' %></div>
            <div class="grid-label"><span>01.7 Marital Status</span><span>:</span></div>
            <div class="grid-value"><%= patient_marital_status || '—' %></div>
        </div>

        <h3 style="font-size: 15px; margin-top: 20px; border-bottom: 1px solid #000; padding-bottom: 5px;">02. Monthly Income Details of the Patient's Family Members</h3>
        <% if (family_incomes_list && family_incomes_list.length > 0) { %>
            <table class="dependents-table">
                <thead>
                    <tr>
                        <th style="width: 30px;">No</th>
                        <th>Name</th>
                        <th>Relationship</th>
                        <th>Marital Status</th>
                        <th>Occupation / Business</th>
                        <th>Monthly Income (Rs.)</th>
                        <th>Tax Payer?</th>
                    </tr>
                </thead>
                <tbody>
                    <% family_incomes_list.forEach((inc, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= inc.name || '—' %></td>
                        <td><%= inc.relationship || '—' %></td>
                        <td><%= inc.civil_status || '—' %></td>
                        <td><%= inc.occupation || '—' %></td>
                        <td><%= inc.income || '—' %></td>
                        <td><%= inc.tax_payer || '—' %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p style="font-size: 14px; color: #555;">No family income details provided.</p>
        <% } %>

        <h3 style="font-size: 15px; margin-top: 20px; border-bottom: 1px solid #000; padding-bottom: 5px;">03. Movable / Immovable Assets and Market Value</h3>
        <% if (assets_list && assets_list.length > 0) { %>
            <table class="dependents-table">
                <thead>
                    <tr>
                        <th style="width: 30px;">No</th>
                        <th>Owner's Name</th>
                        <th>Relationship</th>
                        <th>Type of Asset</th>
                        <th>Market Value (Rs.)</th>
                    </tr>
                </thead>
                <tbody>
                    <% assets_list.forEach((ast, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= ast.owner_name || '—' %></td>
                        <td><%= ast.relationship || '—' %></td>
                        <td><%= ast.description || '—' %></td>
                        <td><%= ast.market_value || '—' %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p style="font-size: 14px; color: #555;">No asset details provided.</p>
        <% } %>

        <h3 style="font-size: 15px; margin-top: 20px; border-bottom: 1px solid #000; padding-bottom: 5px;">04. Fixed/Current Bank Account Deposits</h3>
        <% if (bank_deposits_list && bank_deposits_list.length > 0) { %>
            <table class="dependents-table">
                <thead>
                    <tr>
                        <th style="width: 30px;">No</th>
                        <th>Owner's Name</th>
                        <th>Relationship</th>
                        <th>Bank Name</th>
                        <th>Branch</th>
                        <th>Account Number</th>
                        <th>Balance (Rs.)</th>
                    </tr>
                </thead>
                <tbody>
                    <% bank_deposits_list.forEach((bank, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= bank.owner_name || '—' %></td>
                        <td><%= bank.relationship || '—' %></td>
                        <td><%= bank.bank_name || '—' %></td>
                        <td><%= bank.branch || '—' %></td>
                        <td><%= bank.account_number || '—' %></td>
                        <td><%= bank.current_balance || '—' %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p style="font-size: 14px; color: #555;">No bank account details provided.</p>
        <% } %>

        <h3 style="font-size: 15px; margin-top: 20px; border-bottom: 1px solid #000; padding-bottom: 5px;">05. Sources of Funds Raised for Treatment Expenses</h3>
        <table class="dependents-table">
            <thead>
                <tr>
                    <th style="width: 30px;">No</th>
                    <th>Source of Funds/Assistance</th>
                    <th>Amount (Rs.)</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>1</td><td>Personal Resources / Assets</td><td><%= cost_personal || '—' %></td></tr>
                <tr><td>2</td><td>Employees' Trust Fund (ETF)</td><td><%= cost_etf || '—' %></td></tr>
                <tr><td>3</td><td>National Insurance Trust Fund (NITF)</td><td><%= cost_nitf || '—' %></td></tr>
                <tr><td>4</td><td>Workplace Medical Assistance Scheme</td><td><%= cost_workplace || '—' %></td></tr>
                <tr><td>5</td><td>Insurance or Welfare Schemes</td><td><%= cost_insurance || '—' %></td></tr>
                <tr><td>6</td><td>Non-Governmental Organizations (NGOs)</td><td><%= cost_ngos || '—' %></td></tr>
                <tr><td>7</td><td>Other Donations</td><td><%= cost_donations || '—' %></td></tr>
                <tr><td>8</td><td>Loans obtained</td><td><%= cost_loans || '—' %></td></tr>
                <tr><td>9</td><td>Others</td><td><%= cost_other_details || '—' %></td></tr>
            </tbody>
        </table>

        <h3 style="font-size: 15px; margin-top: 20px; border-bottom: 1px solid #000; padding-bottom: 5px;">06. Previous Assistance from the President’s Fund</h3>
        <div class="grid-details">
            <div class="grid-label"><span>Received assistance before?</span><span>:</span></div>
            <div class="grid-value"><%= prev_assistance || 'No' %></div>
            <% if (prev_assistance === 'Yes') { %>
                <div class="grid-label"><span>Amount received (Rs.)</span><span>:</span></div>
                <div class="grid-value"><%= prev_amount || '—' %></div>
                <div class="grid-label"><span>Date</span><span>:</span></div>
                <div class="grid-value"><%= prev_date || '—' %></div>
                <div class="grid-label"><span>Illness / Treatment</span><span>:</span></div>
                <div class="grid-value"><%= prev_illness || '—' %></div>
                <div class="grid-label"><span>File Number</span><span>:</span></div>
                <div class="grid-value"><%= prev_file_number || '—' %></div>
            <% } %>
        </div>

        <h3 style="font-size: 15px; margin-top: 20px; border-bottom: 1px solid #000; padding-bottom: 5px;">07. Recommendation (Grama Niladhari)</h3>
        <div class="grid-details">
            <div class="grid-label"><span>Recommendation Status</span><span>:</span></div>
            <div class="grid-value"><%= gn_recommendation || 'Recommended' %></div>
            <div class="grid-label"><span>Reason (if any)</span><span>:</span></div>
            <div class="grid-value"><%= gn_reason || '—' %></div>
        </div>

        <%/* GN signature only – no DS block for this cert type */%>
        <div class="signatures">
            <div class="signature-box">
                <% if (gn_signature_img) { %>
                    <img class="signature-img" src="<%= gn_signature_img %>" alt="Grama Niladhari Signature">
                <% } else { %>
                    <div style="height: 80px; line-height: 80px; font-style: italic; color: #999;">Grama Niladhari</div>
                <% } %>
                <div class="caption">
                    <strong>Grama Niladhari (<%= (dynamic_data && dynamic_data.gn_name) ? dynamic_data.gn_name : "Maspanna Division" %>)</strong><br>
                    Digitally Signed
                </div>
            </div>
        </div>

    <% } else if (cert_type === "Registration of delayed births") { %>
        <%
            const personName = (dynamic_data && dynamic_data.person_name) || '—';
            const birthPlace = (dynamic_data && dynamic_data.birth_place) || '—';
            const fatherName = (dynamic_data && dynamic_data.father_name) || '—';
            const motherName = (dynamic_data && dynamic_data.mother_name) || '—';
            
            const passportNum = (dynamic_data && dynamic_data.passport_number) || '—';
            const dlNum = (dynamic_data && dynamic_data.driving_license_number) || '—';
            const occ = (dynamic_data && dynamic_data.occupation) || '—';
            const address = (dynamic_data && dynamic_data.address) || '—';
            const age = (dynamic_data && dynamic_data.age) || '—';
        %>

        <div style="text-align: center; font-size: 18px; font-weight: bold; margin-bottom: 12px; text-decoration: underline;">
            Late Birth Registration - Grama Niladhari Report
        </div>

        <div class="grid-details" style="margin-bottom: 10px; row-gap: 8px;">
            <div class="grid-label"><span>Full Name</span><span>:</span></div>
            <div class="grid-value"><%= applicant_name %></div>

            <div class="grid-label"><span>Address</span><span>:</span></div>
            <div class="grid-value"><%= address %></div>

            <div class="grid-label"><span>Occupation</span><span>:</span></div>
            <div class="grid-value"><%= occ %></div>
        </div>

        <h4 style="margin-top: 10px; margin-bottom: 10px; text-decoration: underline; font-size: 15px;">Identification Information:</h4>
        <div class="grid-details" style="margin-bottom: 15px; row-gap: 8px;">
            <div class="grid-label"><span>NIC Number</span><span>:</span></div>
            <div class="grid-value"><%= nic_number %></div>

            <div class="grid-label"><span>Passport Number</span><span>:</span></div>
            <div class="grid-value"><%= passportNum %></div>

            <div class="grid-label"><span>Driving License Number</span><span>:</span></div>
            <div class="grid-value"><%= dlNum %></div>

            <div class="grid-label"><span>Age</span><span>:</span></div>
            <div class="grid-value"><%= age %></div>
        </div>

        <div style="line-height: 1.6; font-size: 14px; margin-top: 15px; margin-bottom: 15px; text-align: justify;">
            <p style="margin: 8px 0;">I hereby certify that I am personally acquainted with <strong style="border-bottom: 1px dotted #333; padding: 0 10px;"><%= applicant_name %></strong> who has submitted this declaration.</p>
            <p style="margin: 8px 0;">It has been reported to me that <strong style="border-bottom: 1px dotted #333; padding: 0 10px;"><%= personName %></strong> was born at <strong style="border-bottom: 1px dotted #333; padding: 0 10px;"><%= birthPlace %></strong> Hospital / Maternity Home.</p>
            <p style="margin: 8px 0;">I further declare that <strong style="border-bottom: 1px dotted #333; padding: 0 10px;"><%= fatherName %></strong> is the father and <strong style="border-bottom: 1px dotted #333; padding: 0 10px;"><%= motherName %></strong> is the mother of the said person.</p>
            <p style="margin: 8px 0;">I confirm that they reside in my division as husband and wife / that the father / mother / both parents are deceased.</p>
            <p style="margin: 8px 0;">I certify that the above information is true and correct.</p>
        </div>

        <div class="signatures-both" style="margin-top: 40px;">
            <div class="ds-signature-box">
                <% if (ds_signature_img) { %>
                    <img class="signature-img" src="<%= ds_signature_img %>" alt="Divisional Secretary Signature">
                <% } %>
                <div class="caption">
                    <strong>Divisional Secretary</strong><br>
                    Digitally Signed &amp; Stamp Verified
                </div>
            </div>

            <div class="signature-box">
                <% if (gn_signature_img) { %>
                    <img class="signature-img" src="<%= gn_signature_img %>" alt="Grama Niladhari Signature">
                <% } else { %>
                    <div style="height: 80px; line-height: 80px; font-style: italic; color: #999;">Awaiting GN Signature</div>
                <% } %>
                <div class="caption">
                    <strong>Grama Niladhari (<%= (dynamic_data && dynamic_data.gn_name) ? dynamic_data.gn_name : "Maspanna Division" %>)</strong><br>
                    Digitally Signed
                </div>
            </div>
        </div>

    <% } else if (cert_type === "Registration of voluntary organizations") { %>
        <%
            const province = (dynamic_data && dynamic_data.province) || '—';
            const district = (dynamic_data && dynamic_data.district) || '—';
            const ds_division = (dynamic_data && dynamic_data.ds_division) || '—';
            const org_name = (dynamic_data && dynamic_data.org_name) || '—';
            const org_address = (dynamic_data && dynamic_data.org_address) || '—';
            const org_nature = (dynamic_data && dynamic_data.org_nature) || '—';
            const commencement_date = (dynamic_data && dynamic_data.commencement_date) || '—';

            const p_name = (dynamic_data && dynamic_data.president_name) || '—';
            const p_addr = (dynamic_data && dynamic_data.president_address) || '—';
            const p_phone = (dynamic_data && dynamic_data.president_phone) || '—';

            const s_name = (dynamic_data && dynamic_data.secretary_name) || '—';
            const s_addr = (dynamic_data && dynamic_data.secretary_address) || '—';
            const s_phone = (dynamic_data && dynamic_data.secretary_phone) || '—';

            const t_name = (dynamic_data && dynamic_data.treasurer_name) || '—';
            const t_addr = (dynamic_data && dynamic_data.treasurer_address) || '—';
            const t_phone = (dynamic_data && dynamic_data.treasurer_phone) || '—';

            const bank_acc = (dynamic_data && dynamic_data.bank_account_number) || '—';
            const bank_branch = (dynamic_data && dynamic_data.bank_branch) || '—';
            const programs = (dynamic_data && dynamic_data.programs_conducted) || '—';
        %>

        <div style="text-align: center; font-size: 18px; font-weight: bold; margin-bottom: 20px; text-decoration: underline;">
            Registration of Voluntary Organization
        </div>

        <div class="grid-details" style="row-gap: 8px;">
            <div class="grid-label"><span>Province</span><span>:</span></div>
            <div class="grid-value"><%= province %></div>
            <div class="grid-label"><span>District</span><span>:</span></div>
            <div class="grid-value"><%= district %></div>
            <div class="grid-label"><span>D.S. Division</span><span>:</span></div>
            <div class="grid-value"><%= ds_division %></div>
            
            <div class="grid-label"><span>Name of the Organization</span><span>:</span></div>
            <div class="grid-value"><%= org_name %></div>
            <div class="grid-label"><span>Address</span><span>:</span></div>
            <div class="grid-value"><%= org_address %></div>
            <div class="grid-label"><span>Subject / Nature</span><span>:</span></div>
            <div class="grid-value"><%= org_nature %></div>
            <div class="grid-label"><span>Date of Commencement</span><span>:</span></div>
            <div class="grid-value"><%= commencement_date %></div>
        </div>

        <h4 style="margin-top: 15px; margin-bottom: 5px; text-decoration: underline; font-size: 15px;">Key Officials:</h4>
        <table class="dependents-table" style="margin-top: 5px; margin-bottom: 15px;">
            <thead>
                <tr>
                    <th>Designation</th>
                    <th>Name</th>
                    <th>Address</th>
                    <th>Phone Number</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>President</strong></td>
                    <td><%= p_name %></td>
                    <td><%= p_addr %></td>
                    <td><%= p_phone %></td>
                </tr>
                <tr>
                    <td><strong>Secretary</strong></td>
                    <td><%= s_name %></td>
                    <td><%= s_addr %></td>
                    <td><%= s_phone %></td>
                </tr>
                <tr>
                    <td><strong>Treasurer</strong></td>
                    <td><%= t_name %></td>
                    <td><%= t_addr %></td>
                    <td><%= t_phone %></td>
                </tr>
            </tbody>
        </table>

        <div class="grid-details" style="row-gap: 8px;">
            <div class="grid-label"><span>Bank Account Number</span><span>:</span></div>
            <div class="grid-value"><%= bank_acc %></div>
            <div class="grid-label"><span>Branch</span><span>:</span></div>
            <div class="grid-value"><%= bank_branch %></div>
        </div>

        <h4 style="margin-top: 15px; margin-bottom: 5px; text-decoration: underline; font-size: 15px;">Programs Conducted During the Last Six Months:</h4>
        <div style="font-size: 14px; white-space: pre-wrap; padding-left: 10px;"><%= programs %></div>

        <div style="line-height: 1.6; font-size: 14px; margin-top: 15px; text-align: justify;">
            <p style="margin: 0;">I hereby request to register our voluntary organization and certify that the details provided above are accurate.</p>
        </div>

        <div style="border: 2px solid #333; padding: 15px; margin-top: 25px; border-radius: 4px;">
            <strong style="text-decoration: underline; font-size: 14px;">Official Recommendations</strong>
            <p style="margin-top: 10px; font-size: 14px; line-height: 1.5;">
                I recommend / do not recommend this registration as the necessary requirements have / have not been fulfilled.
            </p>
        </div>

        <div class="signatures-both" style="margin-top: 30px;">
            <div class="ds-signature-box">
                <% if (ds_signature_img) { %>
                    <img class="signature-img" src="<%= ds_signature_img %>" alt="Divisional Secretary Signature">
                <% } %>
                <div class="caption">
                    <strong>Divisional Secretary</strong><br>
                    Digitally Signed &amp; Stamp Verified
                </div>
            </div>

            <div class="signature-box">
                <% if (gn_signature_img) { %>
                    <img class="signature-img" src="<%= gn_signature_img %>" alt="Grama Niladhari Signature">
                <% } else { %>
                    <div style="height: 80px; line-height: 80px; font-style: italic; color: #999;">Awaiting GN Signature</div>
                <% } %>
                <div class="caption">
                    <strong>Grama Niladhari (<%= (dynamic_data && dynamic_data.gn_name) ? dynamic_data.gn_name : "Maspanna Division" %>)</strong><br>
                    Digitally Signed
                </div>
            </div>
        </div>

    <% } else { %>

        <%/* ── Generic layout for all other certificate types ── */%>
        <div class="grid-details">
            <div class="grid-label"><span>Applicant Name</span><span>:</span></div>
            <div class="grid-value"><%= applicant_name %></div>

            <div class="grid-label"><span>NIC Number</span><span>:</span></div>
            <div class="grid-value"><%= nic_number %></div>

            <div class="grid-label"><span>Purpose</span><span>:</span></div>
            <div class="grid-value"><%= purpose || '—' %></div>

            <% if (dynamic_data && typeof dynamic_data === 'object') {
                Object.entries(dynamic_data).forEach(([key, val]) => {
                    const excluded = ["gn_name", "div_secretary", "housing_officer", "notes", "dependents"];
                    if (!excluded.includes(key) && val) {
                        const label = key.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
            %>
                <div class="grid-label"><span><%= label %></span><span>:</span></div>
                <div class="grid-value"><%= val %></div>
            <%      }
                });
               }
            %>
        </div>

        <% if (dynamic_data && dynamic_data.dependents && Array.isArray(dynamic_data.dependents) && dynamic_data.dependents.length > 0) { %>
            <h4 style="margin-top: 40px; margin-bottom: 15px; font-size: 16px;">Information Regarding Dependents</h4>
            <table class="dependents-table">
                <thead>
                    <tr>
                        <th style="width: 50px;">No.</th>
                        <th>Name</th>
                        <th>Relationship</th>
                        <th style="width: 80px;">Age</th>
                    </tr>
                </thead>
                <tbody>
                    <% dynamic_data.dependents.forEach((dep, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= dep.name || '—' %></td>
                        <td><%= dep.relationship || '—' %></td>
                        <td><%= dep.age || '—' %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>

        <% if (dynamic_data && dynamic_data.notes) { %>
            <div class="notes-section">
                <h4 style="margin-top: 0; margin-bottom: 10px;">Notes</h4>
                <div style="font-size: 14px; white-space: pre-wrap;"><%= dynamic_data.notes %></div>
            </div>
        <% } %>

        <div class="signatures-both">
            <div class="ds-signature-box">
                <% if (ds_signature_img) { %>
                    <img class="signature-img" src="<%= ds_signature_img %>" alt="Divisional Secretary Signature">
                <% } else { %>
                    <div style="height: 80px; line-height: 80px; font-style: italic; color: #999;">Awaiting DS Signature</div>
                <% } %>
                <div class="caption">
                    <strong>Divisional Secretary</strong><br>
                    Digitally Signed &amp; Stamp Verified
                </div>
            </div>

            <div class="signature-box">
                <% if (gn_signature_img) { %>
                    <img class="signature-img" src="<%= gn_signature_img %>" alt="Grama Niladhari Signature">
                <% } else { %>
                    <div style="height: 80px; line-height: 80px; font-style: italic; color: #999;">Awaiting GN Signature</div>
                <% } %>
                <div class="caption">
                    <strong>Grama Niladhari (<%= (dynamic_data && dynamic_data.gn_name) ? dynamic_data.gn_name : "Maspanna Division" %>)</strong><br>
                    Digitally Signed
                </div>
            </div>
        </div>

    <% } %>
</body>
</html>
